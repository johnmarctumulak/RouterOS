{
    "name": "routeros/api-client",
    "description": "Fast, secure, zero-dependency PHP 8.2+ client for the MikroTik RouterOS API.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": ">=8.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^11",
        "phpstan/phpstan": "^1",
        "friendsofphp/php-cs-fixer": "^3"
    },
    "autoload": {
        "psr-4": {
            "RouterOS\\": "src/RouterOS/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "RouterOS\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test":   "phpunit --testdox",
        "analyse": "phpstan analyse src --level=9",
        "cs-fix": "php-cs-fixer fix src"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "audit": {
            "ignore": ["PKSA-5jz8-6tcw-pbk4", "PKSA-z3gr-8qht-p93v"]
        }
    },
    "keywords": ["mikrotik", "routeros", "api", "networking", "router"]
}
